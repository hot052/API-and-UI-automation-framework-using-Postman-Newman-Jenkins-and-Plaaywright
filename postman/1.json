{
	"info": {
		"_postman_id": "6ea3db0f-dd8b-4be0-8efe-8a10257d1553",
		"name": "Day1",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "20774297"
	},
	"item": [
		{
			"name": "GetUsers",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 200\", function() {",
							"    pm.response.to.have.status(200);",
							"",
							"});",
							"",
							"const json= pm.response.json();",
							"pm.test(\"first user exists\" , function() {",
							"    pm.expect(json[0].name).to.exist;",
							"",
							"});",
							"pm.environment.set(\"userId\", json[0].id);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "x-api-key",
						"value": "YOUR_API_KEY",
						"type": "text",
						"disabled": true
					}
				],
				"url": {
					"raw": "{{baseUrl}}/users",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"users"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Users By ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const json = pm.response.json();",
							"",
							"pm.test(\"Status is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"User object exists\", function () {",
							"    pm.expect(json).to.be.an(\"object\");",
							"});",
							"",
							"pm.test(\"User has id\", function () {",
							"    pm.expect(json).to.have.property(\"id\");",
							"});",
							"",
							"pm.test(\"User ID matches environment\", function () {",
							"    const envId = parseInt(pm.environment.get(\"userId\"));",
							"    pm.expect(json.id).to.eql(envId);",
							"});",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}//users/{{userId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"",
						"users",
						"{{userId}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Invalid User",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"User not found should return empty object\", function() {",
							"    const json =pm.response.json();",
							"    pm.expect(Object.keys(json).length).to.eql(0);",
							"});",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/users/9999",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"users",
						"9999"
					]
				}
			},
			"response": []
		}
	]
}